# ──────────────────────────────────────────────────────────
# AI Guardian — .gitignore
# ──────────────────────────────────────────────────────────

# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.whl

# ── Virtual environments ────────────────────────────────
.venv/
venv/
ENV/

# ── IDE / Editor ────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── Environment variables ───────────────────────────────
.env
.env.local
.env.production
.env.staging

# ── Database ────────────────────────────────────────────
*.db
*.sqlite3
*.db-journal

# ── Node / Frontend ────────────────────────────────────
node_modules/
frontend/dist/
frontend/.tsbuildinfo
*.tsbuildinfo

# ── Testing ─────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage/

# ── Logs ────────────────────────────────────────────────
*.log
logs/

# ── OS ──────────────────────────────────────────────────
.DS_Store
ehthumbs.db

# ── Misc ────────────────────────────────────────────────
*.bak
*.tmp
*.temp
